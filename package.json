{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "linkit",
  "title": "LinkIt",
  "description": "Search the web for your selected text and paste back markdown links",
  "icon": "extension-icon.png",
  "author": "avital_ben_natan",
  "categories": [
    "Productivity",
    "Web"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "index",
      "title": "Search & Link Selected Text",
      "description": "Search DuckDuckGo for selected text and paste markdown links",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2",
    "node-html-parser": "^6.1.13"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "22.13.9",
    "@types/react": "19.0.10",
    "eslint": "^8.57.1",
    "prettier": "^3.4.2",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "ray build --skip-types -e dist -o dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
